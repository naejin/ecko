# ecko.yaml - project-level configuration for the ecko plugin
# Place this file in your project root to customize behavior.

# Auto-fix settings (Layer 1)
autofix:
  enabled: true              # default: true
  black: true                # default: true (if installed)
  isort: true                # default: true (if installed)
  prettier: true             # default: true (if installed)

# Deep analysis settings (Layer 3)
deep_analysis:
  tsc: true                  # default: true (if tsconfig.json exists)
  pyright: true              # default: true (if installed)
  vulture: true              # default: true (if installed)
  knip: true                 # default: true (if installed)

# Custom rules - banned regex patterns
# glob: matches against both the file basename and the path relative to
# the project root, so "*.tsx" and "src/components/*.tsx" both work.
banned_patterns:
  - pattern: "bg-(blue|red|green)-\\d+"
    glob: "*.tsx"
    message: "Use brand color utilities instead of raw Tailwind colors"

# Obsolete terms - flag old names that should be renamed
obsolete_terms:
  - old: "UserProfile"
    new: "Account"

# Import layer rules — architecture boundary enforcement
# Prevents modules from importing across layer boundaries.
# Each rule specifies which files (by glob) are denied from importing which modules.
import_rules: []
  # - files: "routes/*.py"
  #   deny_import:
  #     - repositories
  #     - sqlalchemy
  #   message: "Routes must not import from the data layer directly"
  # - files: "components/*.tsx"
  #   deny_import:
  #     - api
  #   message: "Components should use hooks, not call API directly"

# Builtin-shadowing allowlist — names allowed to shadow Python builtins (A001/A002)
# When set, REPLACES the default allowlist entirely.
# To extend the default, copy all default entries plus your additions.
# Default: type, help, input, format, id, dir, open, filter, map, hash,
#          min, max, range, slice, vars, locals, globals, property, repr, ascii
# builtin_shadow_allowlist:
#   - type
#   - help
#   - input
#   - format
#   - id
#   - custom_name

# Echo cap per check per file — limits repeated echoes of the same check
# Default: 5 (0 = unlimited). Useful for noisy checks like var-declarations.
# echo_cap_per_check: 5

# Exclude files from all checks (glob patterns, matched against relative paths)
# Built-in: any file under a directory named fixtures, __fixtures__,
# __snapshots__, vendor, node_modules, .git, dist, build, or __pycache__
# is automatically excluded at any depth.
# Add your own glob patterns below (matched via fnmatch against relative paths):
exclude: []
  # - "generated/*"
  # - "*.min.js"

# Blocked bash commands — PreToolUse hook blocks these patterns
# Hardcoded (always active):
#   git commit --no-verify, rm -rf /, rm -rf ~,
#   git push --force (use --force-with-lease), git reset --hard,
#   git clean -f (use -n to preview first)
# Add your own patterns below:
blocked_commands: []
  # - pattern: "(pytest|npm test|cargo test).*\\|"
  #   message: "Do not pipe test output — run tests directly for full context"
  # - pattern: "git push.*--force(?!-with-lease)"
  #   message: "Use --force-with-lease instead of --force"

# Reverb — show a tip to run /ecko:reverb when echoes are found on stop
# Use /ecko:reverb to capture session notes, then /ecko:tune to turn them into rules
reverb:
  enabled: false             # default: false

# Session ledger — rolling window for self-correction tracking
# Records echo counts per file per hook invocation in .ecko-session/ledger.jsonl
# session_hours: 4           # default: 4 (rolling window in hours, 0 = disabled)

# Cross-file echo cap — per-check limit across all files in stop mode output
# Useful when the same check floods output across many files
# Default: 0 (unlimited). Per-file cap (echo_cap_per_check) still applies.
# echo_cap_cross_file: 15

# Extra ruff rules — append additional ruff rule codes to ecko's built-in checks
# Accepts full codes (C901, N801) and category prefixes (UP, SIM, C4).
# Unmapped codes use their lowercased code as the check name (e.g., C901 -> c901).
# These are additive — ecko's built-in rules always run.
# See https://docs.astral.sh/ruff/rules/ for all available rule codes.
# ruff_extra_rules:
#   - C901     # function complexity
#   - N801     # class name should use CapWords
#   - UP       # pyupgrade (all rules in category)
#   - SIM101   # use a single if instead of nested ifs

# Disable specific built-in checks (by ecko check name)
# Available checks: unused-imports, singleton-comparison, bare-except,
#   star-imports, mutable-default-args, builtin-shadowing,
#   empty-block-statements (biome),
#   unreachable-code, debugger-statements, var-declarations, duplicate-keys,
#   useless-catch, unicode-artifact, banned-pattern, obsolete-term,
#   type-error, dead-code, unused-file, unused-export,
#   test-conditional, fixed-wait, mock-spec-bypass, import-layer,
#   placeholder-code
disabled_checks: []
