{
  "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "all": false,
      "correctness": {
        "noUnusedImports": "error",
        "noUnreachable": "error"
      },
      "suspicious": {
        "noDebugger": "error",
        "noDuplicateObjectKeys": "error",
        "noEmptyBlockStatements": "error"
      },
      "style": {
        "noVar": "error",
        "useSingleVarDeclarator": "off"
      },
      "complexity": {
        "noUselessCatch": "error"
      }
    }
  },
  "formatter": {
    "enabled": false
  },
  "organizeImports": {
    "enabled": false
  }
}
